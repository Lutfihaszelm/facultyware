<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
        };
        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
        });
      })();
    </script>
    <script>
      (function () {
        try {
          const storedTheme = localStorage.getItem("themeVariant");
          if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
        } catch (event) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — FacultyWare</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body>
    <%- include('../partials/sidebar', { active: 'equipment-categories' }) %>

    <main id="content">
      <%- include('../partials/topbar', { title: 'Edit Kategori Aset' }) %>

      <div class="p-6 max-w-2xl">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-1.5 text-sm text-muted-foreground mb-6">
          <a href="/equipment-categories" class="hover:text-foreground transition-colors">Kategori Aset</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="text-foreground font-medium">Edit Kategori</span>
        </nav>

        <div class="card">
          <div class="card-header">
            <h1 class="card-title">Edit Kategori</h1>
            <p class="card-description">Perbarui informasi kategori <strong><%= category.name %></strong></p>
          </div>
          <div class="card-content">
            <form method="POST" action="/equipment-categories/<%= category.id %>" class="space-y-5">
              <input type="hidden" name="_method" value="PUT">

              <!-- Kode -->
              <div class="space-y-1.5">
                <label for="code" class="label">
                  Kode Kategori <span class="text-destructive">*</span>
                </label>
                <input
                  type="text"
                  id="code"
                  name="code"
                  class="input <%= errors.find(e => e.path === 'code') ? 'border-destructive' : '' %>"
                  placeholder="cth: KAT-001"
                  maxlength="50"
                  value="<%= category.code || '' %>"
                  required
                />
                <% const codeErr = errors.find(e => e.path === 'code'); %>
                <% if (codeErr) { %>
                <p class="text-destructive text-xs"><%= codeErr.msg %></p>
                <% } %>
              </div>

              <!-- Nama -->
              <div class="space-y-1.5">
                <label for="name" class="label">
                  Nama Kategori <span class="text-destructive">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="input <%= errors.find(e => e.path === 'name') ? 'border-destructive' : '' %>"
                  placeholder="cth: Peralatan Komputer"
                  maxlength="255"
                  value="<%= category.name || '' %>"
                  required
                />
                <% const nameErr = errors.find(e => e.path === 'name'); %>
                <% if (nameErr) { %>
                <p class="text-destructive text-xs"><%= nameErr.msg %></p>
                <% } %>
              </div>

              <!-- Deskripsi -->
              <div class="space-y-1.5">
                <label for="description" class="label">Deskripsi <span class="text-muted-foreground text-xs">(opsional)</span></label>
                <textarea
                  id="description"
                  name="description"
                  class="input min-h-24 resize-y"
                  placeholder="Deskripsi singkat tentang kategori ini..."
                  maxlength="1000"
                ><%= category.description || '' %></textarea>
                <% const descErr = errors.find(e => e.path === 'description'); %>
                <% if (descErr) { %>
                <p class="text-destructive text-xs"><%= descErr.msg %></p>
                <% } %>
              </div>

              <!-- Actions -->
              <div class="flex gap-3 pt-2">
                <button type="submit" class="btn btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                  Perbarui Kategori
                </button>
                <a href="/equipment-categories" class="btn btn-outline">Batal</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/scripts') %>
  </body>
</html>
