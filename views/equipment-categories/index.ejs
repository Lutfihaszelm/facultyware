<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
        };
        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
        });
      })();
    </script>
    <script>
      (function () {
        try {
          const storedTheme = localStorage.getItem("themeVariant");
          if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
        } catch (event) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — FacultyWare</title>
    <meta name="description" content="Manajemen Kategori Aset Peralatan FacultyWare" />
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body>
    <%- include('../partials/sidebar', { active: 'equipment-categories' }) %>

    <main id="content">
      <%- include('../partials/topbar', { title: 'Kategori Aset' }) %>

      <div class="p-6 space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold tracking-tight">Kategori Aset Peralatan</h1>
            <p class="text-muted-foreground text-sm mt-1">Kelola kategori untuk mengklasifikasikan aset peralatan</p>
          </div>
          <div class="flex gap-2">
            <a href="/equipment-categories/export?format=csv" class="btn btn-outline btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              Export CSV
            </a>
            <a href="/equipment-categories/export?format=xlsx" class="btn btn-outline btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              Export Excel
            </a>
            <a href="/equipment-categories/create" class="btn btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
              Tambah Kategori
            </a>
          </div>
        </div>

        <!-- Flash Messages -->
        <% if (success) { %>
        <div class="alert alert-success" role="alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <%= success %>
        </div>
        <% } %>
        <% if (error) { %>
        <div class="alert alert-destructive" role="alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
          <%= error %>
        </div>
        <% } %>

        <!-- Table Card -->
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Daftar Kategori</h2>
            <p class="card-description">Total <strong><%= categories.length %></strong> kategori terdaftar</p>
          </div>
          <div class="card-content p-0">
            <% if (categories.length === 0) { %>
            <div class="flex flex-col items-center justify-center py-16 gap-3 text-muted-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
              <p class="text-sm">Belum ada kategori. <a href="/equipment-categories/create" class="underline underline-offset-4">Tambah sekarang</a></p>
            </div>
            <% } else { %>
            <table class="table">
              <thead>
                <tr>
                  <th>Kode</th>
                  <th>Nama Kategori</th>
                  <th>Deskripsi</th>
                  <th class="text-center">Jumlah Aset</th>
                  <th>Dibuat</th>
                  <th class="text-right">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% categories.forEach(cat => { %>
                <tr>
                  <td><span class="badge badge-outline font-mono"><%= cat.code %></span></td>
                  <td class="font-medium"><%= cat.name %></td>
                  <td class="text-muted-foreground text-sm max-w-xs truncate"><%= cat.description || '-' %></td>
                  <td class="text-center">
                    <span class="badge"><%= cat.equipment_count %></span>
                  </td>
                  <td class="text-muted-foreground text-sm">
                    <%= cat.created_at ? new Date(cat.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %>
                  </td>
                  <td class="text-right">
                    <div class="flex justify-end gap-1">
                      <a href="/equipment-categories/<%= cat.id %>/edit" class="btn btn-outline btn-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Edit
                      </a>
                      <form action="/equipment-categories/<%= cat.id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('Hapus kategori \'<%= cat.name %>\'? Aksi ini tidak bisa dibatalkan.')">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="btn btn-destructive btn-sm">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                          Hapus
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } %>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/scripts') %>
  </body>
</html>
