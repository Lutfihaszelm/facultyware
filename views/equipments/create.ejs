<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
        };
        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
        });
      })();
    </script>
    <script>
      (function () {
        try {
          const storedTheme = localStorage.getItem("themeVariant");
          if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — FacultyWare</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body>
    <%- include('../partials/sidebar', { active: 'equipments' }) %>

    <main id="content">
      <%- include('../partials/topbar', { title: 'Tambah Aset Peralatan' }) %>

      <div class="p-6 max-w-3xl">
        <nav class="flex items-center gap-1.5 text-sm text-muted-foreground mb-6">
          <a href="/equipments" class="hover:text-foreground transition-colors">Aset Peralatan</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="text-foreground font-medium">Tambah Aset</span>
        </nav>

        <form method="POST" action="/equipments" enctype="multipart/form-data" class="space-y-6">

          <!-- Informasi Aset -->
          <div class="card">
            <div class="card-header">
              <h1 class="card-title">Informasi Aset</h1>
              <p class="card-description">Data pokok aset peralatan</p>
            </div>
            <div class="card-content space-y-4">
              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                  <label for="name" class="label">Nama Aset <span class="text-destructive">*</span></label>
                  <input type="text" id="name" name="name" class="input <%= errors.find(e=>e.path==='name') ? 'border-destructive' : '' %>"
                    placeholder="cth: Laptop Dell XPS" maxlength="255" value="<%= old.name || '' %>" required />
                  <% const nameErr = errors.find(e=>e.path==='name'); if (nameErr) { %><p class="text-destructive text-xs"><%= nameErr.msg %></p><% } %>
                </div>
                <div class="space-y-1.5">
                  <label for="code" class="label">Kode Aset <span class="text-destructive">*</span></label>
                  <input type="text" id="code" name="code" class="input <%= errors.find(e=>e.path==='code') ? 'border-destructive' : '' %>"
                    placeholder="cth: IT-2024-001" maxlength="100" value="<%= old.code || '' %>" required />
                  <% const codeErr = errors.find(e=>e.path==='code'); if (codeErr) { %><p class="text-destructive text-xs"><%= codeErr.msg %></p><% } %>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                  <label for="acquisition_type" class="label">Jenis Perolehan <span class="text-destructive">*</span></label>
                  <select id="acquisition_type" name="acquisition_type" class="input" required>
                    <option value="">Pilih jenis...</option>
                    <option value="procurement" <%= old.acquisition_type === 'procurement' ? 'selected' : '' %>>Pembelian (Procurement)</option>
                    <option value="grant" <%= old.acquisition_type === 'grant' ? 'selected' : '' %>>Hibah (Grant)</option>
                  </select>
                  <% const acqErr = errors.find(e=>e.path==='acquisition_type'); if (acqErr) { %><p class="text-destructive text-xs"><%= acqErr.msg %></p><% } %>
                </div>
                <div class="space-y-1.5">
                  <label for="acquisition_date" class="label">Tanggal Perolehan <span class="text-destructive">*</span></label>
                  <input type="date" id="acquisition_date" name="acquisition_date" class="input" value="<%= old.acquisition_date || '' %>" required />
                  <% const dateErr = errors.find(e=>e.path==='acquisition_date'); if (dateErr) { %><p class="text-destructive text-xs"><%= dateErr.msg %></p><% } %>
                </div>
              </div>

              <div class="space-y-1.5">
                <label for="acquisition_cost" class="label">Biaya Perolehan (Rp) <span class="text-muted-foreground text-xs">(opsional)</span></label>
                <input type="number" id="acquisition_cost" name="acquisition_cost" class="input"
                  placeholder="0" min="0" step="0.01" value="<%= old.acquisition_cost || '' %>" />
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                  <label for="condition" class="label">Kondisi <span class="text-destructive">*</span></label>
                  <select id="condition" name="condition" class="input" required>
                    <option value="">Pilih kondisi...</option>
                    <option value="good" <%= old.condition === 'good' ? 'selected' : '' %>>Baik</option>
                    <option value="minor_damage" <%= old.condition === 'minor_damage' ? 'selected' : '' %>>Rusak Ringan</option>
                    <option value="major_damage" <%= old.condition === 'major_damage' ? 'selected' : '' %>>Rusak Berat</option>
                  </select>
                </div>
                <div class="space-y-1.5">
                  <label for="status" class="label">Status <span class="text-destructive">*</span></label>
                  <select id="status" name="status" class="input" required>
                    <option value="">Pilih status...</option>
                    <option value="available" <%= old.status === 'available' ? 'selected' : '' %>>Tersedia</option>
                    <option value="in_use" <%= old.status === 'in_use' ? 'selected' : '' %>>Digunakan</option>
                    <option value="maintenance" <%= old.status === 'maintenance' ? 'selected' : '' %>>Dalam Perbaikan</option>
                    <option value="retired" <%= old.status === 'retired' ? 'selected' : '' %>>Tidak Aktif</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <!-- Detail Teknis -->
          <div class="card">
            <div class="card-header">
              <h2 class="card-title">Detail Teknis</h2>
              <p class="card-description">Semua field di bawah ini opsional</p>
            </div>
            <div class="card-content space-y-4">
              <div class="grid grid-cols-3 gap-4">
                <div class="space-y-1.5">
                  <label for="brand" class="label">Merek</label>
                  <input type="text" id="brand" name="brand" class="input" placeholder="cth: Dell, HP, Apple" maxlength="255" value="<%= old.brand || '' %>" />
                </div>
                <div class="space-y-1.5">
                  <label for="model" class="label">Model</label>
                  <input type="text" id="model" name="model" class="input" placeholder="cth: XPS 13 9310" maxlength="255" value="<%= old.model || '' %>" />
                </div>
                <div class="space-y-1.5">
                  <label for="serial_number" class="label">Nomor Seri</label>
                  <input type="text" id="serial_number" name="serial_number" class="input" placeholder="cth: SN12345678" maxlength="255" value="<%= old.serial_number || '' %>" />
                </div>
              </div>

              <div class="space-y-1.5">
                <label for="specification" class="label">Spesifikasi</label>
                <textarea id="specification" name="specification" class="input min-h-24 resize-y" placeholder="Tuliskan spesifikasi teknis (RAM, Storage, Prosesor, dll)..."><%= old.specification || '' %></textarea>
              </div>

              <div class="space-y-1.5">
                <label for="purchase_link" class="label">Link Pembelian / Referensi</label>
                <input type="url" id="purchase_link" name="purchase_link" class="input" placeholder="https://..." value="<%= old.purchase_link || '' %>" />
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                  <label for="depreciation_value" class="label">Nilai Penyusutan (Rp/tahun)</label>
                  <input type="number" id="depreciation_value" name="depreciation_value" class="input" placeholder="0" min="0" step="0.01" value="<%= old.depreciation_value || '' %>" />
                </div>
                <div class="space-y-1.5">
                  <label for="useful_life" class="label">Masa Manfaat (tahun)</label>
                  <input type="number" id="useful_life" name="useful_life" class="input" placeholder="0" min="0" value="<%= old.useful_life || '' %>" />
                </div>
              </div>
            </div>
          </div>

          <!-- Foto -->
          <div class="card">
            <div class="card-header">
              <h2 class="card-title">Foto Aset</h2>
              <p class="card-description">Opsional · Maks. 2MB · Format: JPG, PNG, WebP</p>
            </div>
            <div class="card-content">
              <input type="file" id="photo" name="photo" class="input" accept="image/jpeg,image/png,image/webp" />
              <div id="photo-preview" class="mt-3 hidden">
                <img id="preview-img" src="" alt="Preview foto" class="h-36 w-auto rounded-md border object-cover" />
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex gap-3">
            <button type="submit" class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              Simpan Aset
            </button>
            <a href="/equipments" class="btn btn-outline">Batal</a>
          </div>
        </form>
      </div>
    </main>

    <%- include('../partials/scripts') %>
    <script>
      document.getElementById('photo').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;
        document.getElementById('preview-img').src = URL.createObjectURL(file);
        document.getElementById('photo-preview').classList.remove('hidden');
      });
    </script>
  </body>
</html>
