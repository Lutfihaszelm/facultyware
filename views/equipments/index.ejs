<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
        };
        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
        });
      })();
    </script>
    <script>
      (function () {
        try {
          const storedTheme = localStorage.getItem("themeVariant");
          if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — FacultyWare</title>
    <meta name="description" content="Daftar Aset Peralatan FacultyWare" />
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body>
    <%- include('../partials/sidebar', { active: 'equipments' }) %>

    <main id="content">
      <%- include('../partials/topbar', { title: 'Aset Peralatan' }) %>

      <div class="p-6 space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold tracking-tight">Aset Peralatan</h1>
            <p class="text-muted-foreground text-sm mt-1">Kelola seluruh aset peralatan fakultas</p>
          </div>
          <div class="flex gap-2">
            <a href="/equipments/export?format=csv<%= q ? '&q='+encodeURIComponent(q) : '' %><%= conditionFilter ? '&condition='+conditionFilter : '' %><%= statusFilter ? '&status='+statusFilter : '' %><%= categoryFilter ? '&category_id='+categoryFilter : '' %>" class="btn-sm-outline">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              Export CSV
            </a>
            <a href="/equipments/export?format=xlsx<%= q ? '&q='+encodeURIComponent(q) : '' %><%= conditionFilter ? '&condition='+conditionFilter : '' %><%= statusFilter ? '&status='+statusFilter : '' %><%= categoryFilter ? '&category_id='+categoryFilter : '' %>" class="btn-sm-outline">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              Export Excel
            </a>
            <% if (can('equipments.create')) { %>
            <a href="/equipments/create" class="btn-sm-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
              Tambah Aset
            </a>
            <% } %>
          </div>
        </div>

        <!-- Flash Messages -->
        <% if (success) { %>
        <div class="alert alert-success" role="alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <%= success %>
        </div>
        <% } %>
        <% if (error) { %>
        <div class="alert alert-destructive" role="alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
          <%= error %>
        </div>
        <% } %>

        <!-- Filter & Search -->
        <div class="card">
          <div class="card-content px-4 py-4">
            <form method="GET" action="/equipments" class="flex gap-3 flex-wrap">
              <div class="flex-1 min-w-56">
                <input type="text" name="q" class="input" placeholder="Cari nama, kode, merek, spesifikasi..." value="<%= q %>" />
              </div>
              <select name="condition" class="input w-44">
                <option value="">Semua Kondisi</option>
                <option value="good" <%= conditionFilter === 'good' ? 'selected' : '' %>>Baik</option>
                <option value="minor_damage" <%= conditionFilter === 'minor_damage' ? 'selected' : '' %>>Rusak Ringan</option>
                <option value="major_damage" <%= conditionFilter === 'major_damage' ? 'selected' : '' %>>Rusak Berat</option>
              </select>
              <select name="status" class="input w-44">
                <option value="">Semua Status</option>
                <option value="available" <%= statusFilter === 'available' ? 'selected' : '' %>>Tersedia</option>
                <option value="in_use" <%= statusFilter === 'in_use' ? 'selected' : '' %>>Digunakan</option>
                <option value="maintenance" <%= statusFilter === 'maintenance' ? 'selected' : '' %>>Perbaikan</option>
                <option value="retired" <%= statusFilter === 'retired' ? 'selected' : '' %>>Tidak Aktif</option>
              </select>
              <select name="category_id" class="input w-48">
                <option value="">Semua Kategori</option>
                <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>" <%= String(categoryFilter) === String(cat.id) ? 'selected' : '' %>><%= cat.name %></option>
                <% }) %>
              </select>
              <button type="submit" class="btn-sm-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                Cari
              </button>
              <% if (q || conditionFilter || statusFilter || categoryFilter) { %>
              <a href="/equipments" class="btn-sm-outline">Reset</a>
              <% } %>
            </form>
          </div>
        </div>

        <!-- Table -->
        <div class="card">
          <div class="card-header px-4">
            <h2 class="card-title">Daftar Aset</h2>
            <p class="card-description">
              <% if (q || conditionFilter || statusFilter) { %>
                Menampilkan <strong><%= pagination.totalRows %></strong> hasil pencarian
              <% } else { %>
                Total <strong><%= pagination.totalRows %></strong> aset peralatan
              <% } %>
            </p>
          </div>
          <div class="card-content p-0">
            <% if (equipments.length === 0) { %>
            <div class="flex flex-col items-center justify-center py-16 gap-3 text-muted-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
              <p class="text-sm">
                <% if (q || conditionFilter || statusFilter) { %>
                  Tidak ada aset yang cocok dengan filter.
                <% } else { %>
                  Belum ada aset. <a href="/equipments/create" class="underline underline-offset-4">Tambah sekarang</a>
                <% } %>
              </p>
            </div>
            <% } else { %>
            <%
              const conditionMap = {
                good:         { label: 'Baik',         cls: 'badge-success' },
                minor_damage: { label: 'Rusak Ringan', cls: 'badge-warning' },
                major_damage: { label: 'Rusak Berat',  cls: 'badge-destructive' },
              };
              const statusMap = {
                available:   { label: 'Tersedia',    cls: 'badge-outline' },
                in_use:      { label: 'Digunakan',   cls: 'badge-secondary' },
                maintenance: { label: 'Perbaikan',   cls: 'badge-warning' },
                retired:     { label: 'Tidak Aktif', cls: 'badge-destructive' },
              };
            %>
            <div class="overflow-x-auto">
              <table class="table">
                <thead>
                  <tr>
                    <th class="w-14">Foto</th>
                    <th>Kode</th>
                    <th>Nama Aset</th>
                    <th>Kategori</th>
                    <th>Merek / Model</th>
                    <th>Kondisi</th>
                    <th>Status</th>
                    <th>Perolehan</th>
                    <th class="text-right">Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% equipments.forEach(eq => {
                    const cond = conditionMap[eq.condition] || { label: eq.condition, cls: '' };
                    const stat = statusMap[eq.status] || { label: eq.status, cls: '' };
                  %>
                  <tr>
                    <td>
                      <% if (eq.photo) { %>
                      <img src="<%= eq.photo %>" alt="<%= eq.name %>" class="size-10 rounded-md object-cover border" />
                      <% } else { %>
                      <div class="size-10 rounded-md bg-muted flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                      </div>
                      <% } %>
                    </td>
                    <td><span class="badge-outline font-mono text-xs"><%= eq.code %></span></td>
                    <td class="font-medium max-w-48 truncate"><%= eq.name %></td>
                    <td class="text-sm">
                      <% if (eq.category_name) { %>
                      <span class="badge-secondary"><%= eq.category_name %></span>
                      <% } else { %>
                      <span class="text-muted-foreground">—</span>
                      <% } %>
                    </td>
                    <td class="text-sm text-muted-foreground">
                      <% if (eq.brand || eq.model) { %>
                      <span class="font-medium text-foreground"><%= eq.brand || '' %></span>
                      <% if (eq.model) { %><span class="ml-1"><%= eq.model %></span><% } %>
                      <% } else { %>—<% } %>
                    </td>
                    <td><span class="<%= cond.cls %>"><%= cond.label %></span></td>
                    <td><span class="<%= stat.cls %>"><%= stat.label %></span></td>
                    <td class="text-sm text-muted-foreground">
                      <%= eq.acquisition_date ? new Date(eq.acquisition_date).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) : '-' %>
                    </td>
                    <td class="text-right">
                      <div class="flex justify-end gap-1">
                        <a href="/equipments/<%= eq.id %>" class="btn-sm-outline">Detail</a>
                        <% if (can('equipments.edit')) { %>
                        <a href="/equipments/<%= eq.id %>/edit" class="btn-sm-outline">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </a>
                        <% } %>
                        <% if (can('equipments.delete')) { %>
                        <form action="/equipments/<%= eq.id %>?_method=DELETE" method="POST"
                          onsubmit="return confirm('Hapus aset \'<%= eq.name %>\'? Tidak dapat dibatalkan.')">
                          <input type="hidden" name="_method" value="DELETE">
                          <button type="submit" class="btn-sm-destructive">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                          </button>
                        </form>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <!-- Pagination -->
            <% if (pagination.totalPages > 1) {
              const qs = (p) => `?page=${p}`
                + (q ? `&q=${encodeURIComponent(q)}` : '')
                + (conditionFilter ? `&condition=${conditionFilter}` : '')
                + (statusFilter ? `&status=${statusFilter}` : '')
                + (categoryFilter ? `&category_id=${categoryFilter}` : '');
            %>
            <div class="flex items-center justify-between px-4 py-3 border-t flex-wrap gap-3">
              <p class="text-sm text-muted-foreground">
                Halaman <strong><%= pagination.page %></strong> dari <strong><%= pagination.totalPages %></strong>
                · <%= pagination.totalRows %> total aset
              </p>
              <div class="flex gap-1">
                <% if (pagination.page > 1) { %>
                <a href="<%= qs(pagination.page - 1) %>" class="btn-sm-outline">Sebelumnya</a>
                <% } %>
                <% for (let p = 1; p <= pagination.totalPages; p++) { %>
                <a href="<%= qs(p) %>" class="<%= p === pagination.page ? 'btn-sm-primary' : 'btn-sm-outline' %>"><%= p %></a>
                <% } %>
                <% if (pagination.page < pagination.totalPages) { %>
                <a href="<%= qs(pagination.page + 1) %>" class="btn-sm-outline">Berikutnya</a>
                <% } %>
              </div>
            </div>
            <% } %>
            <% } %>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/scripts') %>
  </body>
</html>
