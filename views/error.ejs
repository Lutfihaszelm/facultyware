<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
        };
        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
        });
      })();
    </script>
    <script>
      (function () {
        try {
          const storedTheme = localStorage.getItem("themeVariant");
          if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Error <%= error.status || 500 %> — FacultyWare</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body>
    <%- include('partials/sidebar', { active: '' }) %>

    <main id="content">
      <%- include('partials/topbar', { title: 'Terjadi Kesalahan' }) %>

      <div class="p-6 max-w-2xl">
        <div class="card">
          <div class="card-header px-4">
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center w-10 h-10 rounded-full bg-destructive/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-destructive"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
              </div>
              <div>
                <h1 class="card-title">
                  <% if (error.status === 404) { %>
                    Halaman Tidak Ditemukan
                  <% } else if (error.status === 403) { %>
                    Akses Ditolak
                  <% } else { %>
                    Terjadi Kesalahan Server
                  <% } %>
                </h1>
                <p class="text-sm text-muted-foreground">Kode error: <%= error.status || 500 %></p>
              </div>
            </div>
          </div>
          <div class="card-content px-4">
            <div class="alert alert-destructive mb-4" role="alert">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
              <%= message %>
            </div>

            <% if (error.status === 404) { %>
              <p class="text-sm text-muted-foreground mb-4">Halaman atau data yang kamu cari tidak ditemukan. Mungkin sudah dihapus atau alamat URL-nya salah.</p>
            <% } else if (error.status === 403) { %>
              <p class="text-sm text-muted-foreground mb-4">Kamu tidak memiliki izin untuk mengakses halaman ini. Hubungi administrator jika ini seharusnya bisa diakses.</p>
            <% } else { %>
              <p class="text-sm text-muted-foreground mb-4">Terjadi kesalahan yang tidak terduga. Coba ulangi tindakan kamu atau kembali ke halaman sebelumnya.</p>
            <% } %>

            <% if (error.stack) { %>
            <details class="mt-2">
              <summary class="text-xs text-muted-foreground cursor-pointer hover:text-foreground">Detail teknis (developer)</summary>
              <pre class="mt-2 text-xs bg-muted p-3 rounded-md overflow-x-auto whitespace-pre-wrap break-all"><%= error.stack %></pre>
            </details>
            <% } %>

            <div class="flex gap-3 mt-6">
              <a href="javascript:history.back()" class="btn-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                Kembali
              </a>
              <a href="/home" class="btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Ke Dashboard
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('partials/scripts') %>
  </body>
</html>
